# BuildMate Frontend Environment Variables

# Google Tag Manager container ID (optional)
# Get this from Google Tag Manager: https://tagmanager.google.com/
# Format: GTM-XXXXXXX
VITE_GTM_ID=

# Facebook Pixel ID (optional)
# Get this from Facebook Events Manager: https://business.facebook.com/events_manager/
# Format: 1234567890
VITE_FB_PIXEL_ID=
