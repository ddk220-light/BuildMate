{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "outDir": "./dist/server",
        "rootDir": "./src/server",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "types": [
            "@cloudflare/workers-types",
            "node"
        ]
    },
    "include": [
        "src/server/**/*"
    ]
}