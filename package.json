{
  "name": "buildmate",
  "version": "1.0.0",
  "description": "AI-powered shopping assistant for complex product builds",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "db:create": "wrangler d1 create buildmate-db",
    "db:migrate": "wrangler d1 execute buildmate-db --file=./migrations/schema.sql",
    "db:migrate:local": "wrangler d1 execute buildmate-db --local --file=./migrations/schema.sql",
    "kv:create": "wrangler kv:namespace create CACHE",
    "tail": "wrangler tail",
    "test": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@hono/zod-validator": "^0.4.0",
    "hono": "^4.0.0",
    "uuid": "^13.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240512.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0",
    "wrangler": "^3.57.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
