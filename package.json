{
    "name": "buildmate",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev:client": "vite",
        "dev:server": "tsx watch src/server/index.ts",
        "dev": "npm run dev:client & npm run dev:server",
        "build:client": "tsc -b tsconfig.app.json && vite build",
        "build:server": "tsup src/server/index.ts --out-dir dist/server --format esm --clean",
        "build": "npm run build:client && npm run build:server",
        "start": "node dist/server/index.js",
        "lint": "eslint .",
        "preview": "vite preview"
    },
    "dependencies": {
        "@hono/node-server": "^1.13.7",
        "cli-table3": "^0.6.5",
        "commander": "^14.0.3",
        "csv-stringify": "^6.6.0",
        "dotenv": "^16.4.5",
        "facebook-nodejs-business-sdk": "^24.0.1",
        "hono": "^4.11.3",
        "pg": "^8.13.1",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-router-dom": "^7.12.0",
        "uuid": "^13.0.0",
        "zod": "^4.3.5"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20260228.0",
        "@eslint/js": "^9.39.1",
        "@tailwindcss/vite": "^4.1.18",
        "@types/node": "^24.10.1",
        "@types/pg": "^8.11.10",
        "@types/react": "^19.2.5",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.1",
        "eslint": "^9.39.1",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.24",
        "globals": "^16.5.0",
        "tailwindcss": "^4.1.18",
        "tsup": "^8.5.1",
        "tsx": "^4.19.2",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.46.4",
        "vite": "^7.2.4"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
