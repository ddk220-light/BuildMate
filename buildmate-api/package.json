{
  "name": "buildmate-api",
  "version": "1.0.0",
  "description": "BuildMate API - AI-powered shopping assistant for product bundles",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy --env production",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:create": "wrangler d1 create buildmate-db",
    "db:migrate:local": "wrangler d1 execute buildmate-db --local --file=./migrations/0001_initial_schema.sql",
    "db:migrate:remote": "wrangler d1 execute buildmate-db --remote --file=./migrations/0001_initial_schema.sql"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "ai",
    "shopping",
    "buildmate"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "hono": "^4.11.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260108.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16",
    "wrangler": "^4.57.0"
  }
}
